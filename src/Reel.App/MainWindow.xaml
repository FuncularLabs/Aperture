<Window x:Class="Reel.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vwp="clr-namespace:WpfToolkit.Controls;assembly=VirtualizingWrapPanel"
        xmlns:vm="clr-namespace:Reel.App.ViewModels"
        xmlns:mvvm="clr-namespace:Reel.App.Mvvm"
        Title="{Binding WindowTitle}" Height="820" Width="1280"
        Icon="Assets/reel.ico"
        Background="#F5F6F8"
        UseLayoutRounding="True" TextOptions.TextFormattingMode="Display">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <mvvm:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />
        <!-- Carries the view model into ContextMenu popups (which can't see the Window via RelativeSource). -->
        <mvvm:BindingProxy x:Key="Vm" Data="{Binding}" />
        <SolidColorBrush x:Key="Panel" Color="#FFFFFF" />
        <SolidColorBrush x:Key="Line" Color="#E2E5EA" />
        <SolidColorBrush x:Key="Ink" Color="#1F2430" />
        <SolidColorBrush x:Key="Muted" Color="#8A90A0" />
        <SolidColorBrush x:Key="Accent" Color="#3A72F0" />
        <SolidColorBrush x:Key="ThumbBg" Color="#EEF0F4" />
        <SolidColorBrush x:Key="SelBg" Color="#E6EEFF" />
        <SolidColorBrush x:Key="SelBorder" Color="#3A72F0" />

        <!-- Toolbar button -->
        <Style x:Key="ToolButton" TargetType="Button">
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Background" Value="{StaticResource Panel}" />
            <Setter Property="Foreground" Value="{StaticResource Ink}" />
            <Setter Property="BorderBrush" Value="{StaticResource Line}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#F0F3FA" />
                                <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource Accent}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="b" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Toolbar toggle button (settings) -->
        <Style x:Key="ToolToggle" TargetType="ToggleButton">
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="b" Background="{StaticResource Panel}" BorderBrush="{StaticResource Line}"
                                BorderThickness="1" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#F0F3FA" />
                                <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource Accent}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#E6EEFF" />
                                <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource Accent}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tile container: minimal chrome + selection ring -->
        <Style x:Key="TileContainer" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="4" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="b" Background="Transparent" CornerRadius="8"
                                BorderBrush="Transparent" BorderThickness="2" Padding="4">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource SelBg}" />
                                <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource SelBorder}" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="False" />
                                    <Condition Property="IsMouseOver" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="b" Property="Background" Value="#F0F2F6" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Collapsible date-section header -->
        <Style x:Key="SectionHeader" TargetType="ToggleButton">
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="True" />
            <Setter Property="Margin" Value="2,10,2,2" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="b" Background="Transparent" CornerRadius="6" Padding="6,5"
                                BorderBrush="Transparent" BorderThickness="1">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#EEF1F6" />
                            </Trigger>
                            <DataTrigger Binding="{Binding Name.IsCursor}" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#E3ECFF" />
                                <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource Accent}" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Per-root status line: hidden when empty -->
        <Style x:Key="RootStatus" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Accent}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
    <DockPanel>

        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Background="{StaticResource Panel}" BorderBrush="{StaticResource Line}"
                BorderThickness="0,0,0,1">
            <DockPanel Margin="12,10">
                <!-- Settings (right) -->
                <ToggleButton x:Name="SettingsToggle" DockPanel.Dock="Right" Content="⚙  Settings"
                              Style="{StaticResource ToolToggle}" Margin="6,0,0,0" />

                <!-- Search (right, left of settings) -->
                <Border DockPanel.Dock="Right" Width="320" Height="30" Background="#F3F4F7"
                        BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="6"
                        Margin="0,0,6,0" VerticalAlignment="Center">
                    <Grid>
                        <TextBlock Text="🔍  Search   tag:  note:  is:video   ( / or Ctrl+F )" Foreground="{StaticResource Muted}" FontSize="12"
                                   Margin="9,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SearchText}" Value="">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBox x:Name="SearchBox" Background="Transparent" BorderThickness="0"
                                 VerticalContentAlignment="Center" Margin="7,0,26,0" FontSize="12"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Content="✕" Command="{Binding ClearSearchCommand}" HorizontalAlignment="Right"
                                Width="24" Background="Transparent" BorderThickness="0" Foreground="{StaticResource Muted}"
                                Cursor="Hand" />
                    </Grid>
                </Border>
                <Popup IsOpen="{Binding IsChecked, ElementName=SettingsToggle}"
                       PlacementTarget="{Binding ElementName=SettingsToggle}" Placement="Bottom"
                       StaysOpen="False" AllowsTransparency="True" HorizontalOffset="-160">
                    <Border Background="{StaticResource Panel}" BorderBrush="{StaticResource Line}"
                            BorderThickness="1" CornerRadius="8" Padding="16" Width="280"
                            Margin="8" SnapsToDevicePixels="True">
                        <Border.Effect>
                            <DropShadowEffect Color="#22000000" BlurRadius="16" ShadowDepth="2" Direction="270" />
                        </Border.Effect>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <Image Source="Assets/mascot.png" Width="34" Height="34" />
                                <StackPanel VerticalAlignment="Center" Margin="10,0,0,0">
                                    <TextBlock Text="{Binding AppVersion}" Foreground="{StaticResource Ink}"
                                               FontWeight="SemiBold" FontSize="14" />
                                    <TextBlock Text="A fast local image &amp; video browser" Foreground="{StaticResource Muted}"
                                               FontSize="11" />
                                </StackPanel>
                            </StackPanel>

                            <TextBlock Text="SETTINGS" Foreground="{StaticResource Muted}" FontSize="11"
                                       FontWeight="SemiBold" Margin="0,0,0,10" />

                            <CheckBox Content="Include videos" IsChecked="{Binding IncludeVideos}"
                                      ToolTip="Index video files and show a thumbnail from the OS shell." />
                            <TextBlock Text="Uses the same frame Explorer shows. Re-indexes when toggled."
                                       Foreground="{StaticResource Muted}" FontSize="11" TextWrapping="Wrap"
                                       Margin="22,2,0,10" />

                            <CheckBox Content="Group into date sections" IsChecked="{Binding GroupByDate}"
                                      Margin="0,0,0,12" />

                            <TextBlock Text="Caption format" Foreground="{StaticResource Ink}" FontSize="12"
                                       FontWeight="SemiBold" Margin="0,0,0,4" />
                            <TextBox Text="{Binding CaptionFormat, UpdateSourceTrigger=LostFocus}" Padding="6,4"
                                     BorderBrush="{StaticResource Line}" BorderThickness="1" />
                            <TextBlock Foreground="{StaticResource Muted}" FontSize="11" TextWrapping="Wrap" Margin="0,3,0,12"
                                       Text="Tokens: {name} {date:fmt} {mtime} {alias} {size} {dim} {camera} {ext}. Use ?? for fallback." />

                            <Border Height="1" Background="{StaticResource Line}" Margin="0,2,0,12" />

                            <Button Content="🏷  Manage tags…" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                    Padding="8,6" Margin="0,0,0,6" Command="{Binding ManageTagsCommand}"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                    Foreground="{StaticResource Ink}" />
                            <Button Content="📖  View README (help)" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                    Padding="8,6" Command="{Binding OpenReadmeCommand}"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                    Foreground="{StaticResource Ink}" />

                        </StackPanel>
                    </Border>
                </Popup>

                <!-- Actions (left) -->
                <StackPanel Orientation="Horizontal">
                    <Image Source="Assets/mascot.png" Width="30" Height="30" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock Text="Reel" FontWeight="Bold" FontSize="17" Foreground="{StaticResource Ink}"
                               VerticalAlignment="Center" Margin="0,0,14,0" />
                    <Button Content="＋  Add Folder" Style="{StaticResource ToolButton}" Command="{Binding AddRootCommand}" />
                    <Rectangle Width="1" Fill="{StaticResource Line}" Margin="6,2" />
                    <Button Content="－" Style="{StaticResource ToolButton}" Click="OnZoomOutClick"
                            ToolTip="Zoom out (Ctrl+-)" MinWidth="36" />
                    <Button Content="＋" Style="{StaticResource ToolButton}" Click="OnZoomInClick"
                            ToolTip="Zoom in (Ctrl++)" MinWidth="36" />
                    <Rectangle Width="1" Fill="{StaticResource Line}" Margin="6,2" />
                    <TextBlock Text="Sort" Foreground="{StaticResource Muted}" VerticalAlignment="Center"
                               Margin="0,0,6,0" FontSize="12" />
                    <ComboBox ItemsSource="{Binding SortLabels}" SelectedItem="{Binding SortPreset, Mode=TwoWay}"
                              Width="120" VerticalAlignment="Center" Height="30" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Background="{StaticResource Panel}" BorderBrush="{StaticResource Line}"
                BorderThickness="0,1,0,0">
            <Grid Margin="12,6">
                <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource Ink}" FontSize="12"
                           VerticalAlignment="Center" />
                <TextBlock Text="{Binding IndexingText}" Foreground="{StaticResource Accent}" FontSize="12"
                           HorizontalAlignment="Right" VerticalAlignment="Center" />
            </Grid>
        </Border>

        <!-- Body -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="210" MinWidth="140" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Roots pane -->
            <Border Grid.Column="0" Background="{StaticResource Panel}" BorderBrush="{StaticResource Line}"
                    BorderThickness="0,0,1,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="FOLDERS" Foreground="{StaticResource Muted}"
                               FontSize="11" FontWeight="SemiBold" Margin="14,12,14,6" />
                    <TreeView x:Name="FolderTreeView" ItemsSource="{Binding FolderTree}"
                              BorderThickness="0" Background="Transparent"
                              SelectedItemChanged="OnTreeSelectedChanged">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                                <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                            </Style>
                        </TreeView.ItemContainerStyle>
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal" Margin="0,1">
                                    <CheckBox IsChecked="{Binding Root.IsIncluded, Mode=TwoWay}" VerticalAlignment="Center"
                                              Margin="0,0,5,0" ToolTip="Include this folder"
                                              Visibility="{Binding IsRoot, Converter={StaticResource BoolToVis}}" />
                                    <TextBlock Text="📁" FontSize="12" Margin="0,0,4,0" VerticalAlignment="Center"
                                               Visibility="{Binding IsRoot, Converter={StaticResource InverseBoolToVis}}" />
                                    <TextBlock Text="{Binding Name}" Foreground="{StaticResource Ink}" VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" MouseLeftButtonDown="OnAliasClick">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Root.IsEditing}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBox Text="{Binding Root.Alias, UpdateSourceTrigger=LostFocus}" MinWidth="80"
                                             Visibility="{Binding Root.IsEditing, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed, TargetNullValue=Collapsed}"
                                             Padding="2,0" BorderBrush="{StaticResource Accent}" BorderThickness="1"
                                             IsVisibleChanged="OnAliasEditVisibleChanged" KeyDown="OnAliasEditKeyDown"
                                             LostFocus="OnAliasEditLostFocus" />
                                    <TextBlock Text="{Binding Count, StringFormat= ({0:n0})}" Foreground="{StaticResource Muted}"
                                               FontSize="11" VerticalAlignment="Center" Margin="4,0,0,0" />
                                    <StackPanel.ContextMenu>
                                        <ContextMenu Visibility="{Binding IsRoot, Converter={StaticResource BoolToVis}}">
                                            <MenuItem Header="Rename" Command="{Binding Root.BeginRenameCommand}" />
                                            <MenuItem Header="Remove folder"
                                                      Command="{Binding Data.RemoveRootCommand, Source={StaticResource Vm}}"
                                                      CommandParameter="{Binding Root}" />
                                        </ContextMenu>
                                    </StackPanel.ContextMenu>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                          Background="Transparent" />

            <!-- Thumbnail grid -->
                <ListBox x:Name="ItemsList" Grid.Column="2"
                     ItemsSource="{Binding ItemsView}"
                     SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                     Background="Transparent" BorderThickness="0" Padding="6"
                     ItemContainerStyle="{StaticResource TileContainer}"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     VirtualizingPanel.ScrollUnit="Pixel"
                     VirtualizingPanel.CacheLength="1,2"
                     VirtualizingPanel.CacheLengthUnit="Page"
                     VirtualizingPanel.IsVirtualizingWhenGrouping="True"
                     MouseDoubleClick="OnItemsDoubleClick"
                     PreviewMouseWheel="OnItemsPreviewMouseWheel"
                     PreviewKeyDown="OnGridKeyDown">
                <ListBox.InputBindings>
                    <KeyBinding Key="Back" Command="{Binding NavigateUpCommand}" />
                </ListBox.InputBindings>
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <vwp:VirtualizingWrapPanel Orientation="Horizontal" SpacingMode="Uniform" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.ContainerStyle>
                            <Style TargetType="GroupItem">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="GroupItem">
                                            <StackPanel>
                                                <ToggleButton IsChecked="{Binding Name.IsExpanded, Mode=TwoWay}"
                                                              Style="{StaticResource SectionHeader}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock x:Name="chev" Text="▾" FontSize="12"
                                                                   Foreground="{StaticResource Muted}"
                                                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                                                        <TextBlock Text="{Binding Name.Label}" FontSize="14"
                                                                   FontWeight="SemiBold" Foreground="{StaticResource Ink}"
                                                                   VerticalAlignment="Center" />
                                                        <TextBlock Text="{Binding ItemCount, StringFormat=  ·  {0:n0}}"
                                                                   FontSize="13" Foreground="{StaticResource Muted}"
                                                                   VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </ToggleButton>
                                                <ItemsPresenter Visibility="{Binding Name.IsExpanded, Converter={StaticResource BoolToVis}}" />
                                            </StackPanel>
                                            <ControlTemplate.Triggers>
                                                <DataTrigger Binding="{Binding Name.IsExpanded}" Value="False">
                                                    <Setter TargetName="chev" Property="Text" Value="▸" />
                                                </DataTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </GroupStyle.ContainerStyle>
                    </GroupStyle>
                </ListBox.GroupStyle>
                <ListBox.Resources>
                    <!-- Media tile -->
                    <DataTemplate DataType="{x:Type vm:TileVm}">
                        <StackPanel Width="{Binding DataContext.TileSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                    ToolTip="{Binding Tooltip}">
                            <StackPanel.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Open"
                                              Command="{Binding Data.OpenSelectedCommand, Source={StaticResource Vm}}" />
                                    <MenuItem Header="Open with" SubmenuOpened="OnOpenWithSubmenuOpened">
                                        <MenuItem Header="" />
                                    </MenuItem>
                                    <Separator />
                                    <MenuItem Header="Tags &amp; notes…"
                                              Command="{Binding Data.EditAnnotationCommand, Source={StaticResource Vm}}"
                                              CommandParameter="{Binding}" />
                                    <Separator />
                                    <MenuItem Header="Copy image" Visibility="{Binding IsVideo, Converter={StaticResource InverseBoolToVis}}"
                                              Command="{Binding Data.CopyImageCommand, Source={StaticResource Vm}}"
                                              CommandParameter="{Binding}" />
                                    <MenuItem Header="Copy thumbnail" Visibility="{Binding IsVideo, Converter={StaticResource BoolToVis}}"
                                              Command="{Binding Data.CopyImageCommand, Source={StaticResource Vm}}"
                                              CommandParameter="{Binding}" />
                                    <MenuItem Header="Copy file name"
                                              Command="{Binding Data.CopyFileNameCommand, Source={StaticResource Vm}}"
                                              CommandParameter="{Binding}" />
                                    <MenuItem Header="Copy full path"
                                              Command="{Binding Data.CopyFullPathCommand, Source={StaticResource Vm}}"
                                              CommandParameter="{Binding}" />
                                    <Separator />
                                    <MenuItem Header="Copy" InputGestureText="Ctrl+C"
                                              Command="{Binding Data.CopyFileCommand, Source={StaticResource Vm}}"
                                              CommandParameter="{Binding}" />
                                    <MenuItem Header="Cut" InputGestureText="Ctrl+X"
                                              Command="{Binding Data.CutFileCommand, Source={StaticResource Vm}}"
                                              CommandParameter="{Binding}" />
                                </ContextMenu>
                            </StackPanel.ContextMenu>
                            <Border Background="{StaticResource ThumbBg}" CornerRadius="6"
                                    Width="{Binding DataContext.TileSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                    Height="{Binding DataContext.TileSize, RelativeSource={RelativeSource AncestorType=Window}}">
                                <Grid>
                                    <!-- Fill the square tile (center-crop) for a clean uniform grid -->
                                    <Border CornerRadius="6" RenderOptions.BitmapScalingMode="HighQuality">
                                        <Border.Background>
                                            <ImageBrush ImageSource="{Binding Thumbnail}" Stretch="UniformToFill" />
                                        </Border.Background>
                                    </Border>
                                    <!-- Video badge -->
                                    <Border HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="7"
                                            Background="#B0000000" CornerRadius="10" Width="20" Height="20"
                                            Visibility="{Binding IsVideo, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="▶" Foreground="White" FontSize="9"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Margin="2,0,0,0" />
                                    </Border>
                                    <!-- Tags/notes badge -->
                                    <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="7"
                                            Background="#CC1F2430" CornerRadius="9" Padding="4,1"
                                            Visibility="{Binding HasAnnotation, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="🏷" FontSize="9" Foreground="White" VerticalAlignment="Center" />
                                    </Border>
                                </Grid>
                            </Border>
                            <TextBlock Text="{Binding Caption}" Foreground="{StaticResource Muted}"
                                       FontSize="11" TextAlignment="Center" TextTrimming="CharacterEllipsis"
                                       Margin="2,4,2,0"
                                       MaxWidth="{Binding DataContext.TileSize, RelativeSource={RelativeSource AncestorType=Window}}" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.Resources>
                </ListBox>
        </Grid>
    </DockPanel>

        <!-- Quick-look overlay -->
        <Grid x:Name="QuickLookOverlay" Background="#EE0E1014" MouseDown="OnQuickLookBackgroundClick"
              Visibility="{Binding QuickLookOpen, Converter={StaticResource BoolToVis}}">
            <Image Source="{Binding QuickLookImage}" Stretch="Uniform" Margin="72,60,72,72"
                   RenderOptions.BitmapScalingMode="HighQuality" IsHitTestVisible="False" />

            <TextBlock Text="{Binding QuickLookCaption}" Foreground="#F0FFFFFF" FontSize="13"
                       HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,20" IsHitTestVisible="False" />

            <Button Content="‹" Command="{Binding QuickLookPrevCommand}" HorizontalAlignment="Left"
                    VerticalAlignment="Center" Width="52" Height="72" Margin="8,0" FontSize="34"
                    Foreground="White" Background="#33FFFFFF" BorderThickness="0" Cursor="Hand" />
            <Button Content="›" Command="{Binding QuickLookNextCommand}" HorizontalAlignment="Right"
                    VerticalAlignment="Center" Width="52" Height="72" Margin="8,0" FontSize="34"
                    Foreground="White" Background="#33FFFFFF" BorderThickness="0" Cursor="Hand" />
            <Button Content="✕" Command="{Binding CloseQuickLookCommand}" HorizontalAlignment="Right"
                    VerticalAlignment="Top" Width="40" Height="40" Margin="16" FontSize="18"
                    Foreground="White" Background="#33FFFFFF" BorderThickness="0" Cursor="Hand" />
            <TextBlock Text="Space or Esc to close  ·  ← → to move" Foreground="#99FFFFFF" FontSize="12"
                       HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,24" IsHitTestVisible="False" />
        </Grid>

        <!-- First-run welcome -->
        <Grid Background="#CC0E1014" Visibility="{Binding ShowFirstRun, Converter={StaticResource BoolToVis}}">
            <Border Background="{StaticResource Panel}" CornerRadius="12" Width="460" Padding="28"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect Color="#44000000" BlurRadius="30" ShadowDepth="4" Direction="270" />
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Welcome to Reel" FontSize="22" FontWeight="Bold" Foreground="{StaticResource Ink}" />
                    <TextBlock Text="Add your photo folders to get started. We found these — pick the ones you want."
                               Foreground="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,6,0,16" />
                    <ItemsControl ItemsSource="{Binding FirstRunCandidates}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsChosen}" Margin="0,4">
                                    <StackPanel Margin="4,0,0,0">
                                        <TextBlock Text="{Binding Alias}" FontWeight="SemiBold" Foreground="{StaticResource Ink}" />
                                        <TextBlock Text="{Binding Path}" Foreground="{StaticResource Muted}" FontSize="11"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </CheckBox>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                        <Button Content="Not now" Style="{StaticResource ToolButton}" Command="{Binding SkipFirstRunCommand}" />
                        <Button Content="Add selected" Style="{StaticResource ToolButton}"
                                Command="{Binding AddChosenFoldersCommand}"
                                Background="#E6EEFF" BorderBrush="{StaticResource Accent}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
