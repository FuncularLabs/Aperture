<Window x:Class="Reel.App.AnnotationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tags &amp; Notes" Height="500" Width="440"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize" MinWidth="360" MinHeight="380"
        Background="#F7F8FA" UseLayoutRounding="True" TextOptions.TextFormattingMode="Display"
        Icon="Assets/aperture.ico">
    <Window.Resources>
        <SolidColorBrush x:Key="Ink" Color="#1F2430" />
        <SolidColorBrush x:Key="Muted" Color="#8A90A0" />
        <SolidColorBrush x:Key="Accent" Color="#3A72F0" />
        <SolidColorBrush x:Key="Line" Color="#E2E5EA" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- Removable tag chip. Shared tags (on every selected item) show a solid
             fill; partial tags (on some) show a dashed outline + a "pertains to" tip. -->
        <DataTemplate x:Key="ChipTemplate">
            <Grid Margin="0,0,7,7" ToolTip="{Binding ScopeTooltip}">
                <Rectangle x:Name="fill" RadiusX="13" RadiusY="13" Fill="#C7DBFF" />
                <Rectangle x:Name="dash" RadiusX="13" RadiusY="13" Fill="#E8EEFA"
                           Stroke="#7E97CC" StrokeThickness="1.4" StrokeDashArray="2 2" Visibility="Collapsed" />
                <StackPanel Orientation="Horizontal" Margin="12,5,6,5">
                    <TextBlock Text="{Binding Name}" Foreground="#16306E" FontSize="14" FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <Button Content="✕" FontSize="11" Margin="7,0,0,0" Padding="3,0" Background="Transparent"
                            BorderThickness="0" Foreground="#375C9E" Cursor="Hand"
                            Command="{Binding DataContext.RemoveTagCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding}" />
                </StackPanel>
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding Shared}" Value="False">
                    <Setter TargetName="fill" Property="Visibility" Value="Collapsed" />
                    <Setter TargetName="dash" Property="Visibility" Value="Visible" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding Header}" Foreground="{StaticResource Ink}" FontWeight="Bold"
                   FontSize="15" TextTrimming="CharacterEllipsis" Margin="0,0,0,14" />

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,6">
            <TextBlock Text="TAGS" Foreground="{StaticResource Muted}" FontSize="11" FontWeight="SemiBold" />
            <TextBlock Text="  ·  adding applies to all;  ✕ removes from all that have it"
                       Foreground="{StaticResource Muted}" FontSize="11"
                       Visibility="{Binding IsMulti, Converter={StaticResource BoolToVis}}" />
        </StackPanel>

        <ItemsControl Grid.Row="2" ItemsSource="{Binding Tags}" ItemTemplate="{StaticResource ChipTemplate}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
        </ItemsControl>

        <Grid Grid.Row="3" Margin="0,2,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="NewTagBox" Grid.Column="0" Text="{Binding NewTag, UpdateSourceTrigger=PropertyChanged}"
                     Padding="6,4" BorderBrush="{StaticResource Line}" BorderThickness="1" VerticalContentAlignment="Center">
                <TextBox.InputBindings>
                    <KeyBinding Key="Return" Command="{Binding AddTagCommand}" />
                </TextBox.InputBindings>
            </TextBox>
            <Button Grid.Column="1" Content="Add" Margin="6,0,0,0" Padding="12,4" Command="{Binding AddTagCommand}" />
        </Grid>

        <StackPanel Grid.Row="4" Margin="0,0,0,12">
            <Grid Margin="0,0,0,4">
                <TextBlock Text="Suggestions" Foreground="{StaticResource Muted}" FontSize="11" VerticalAlignment="Center" />
                <!-- Expand/collapse the suggestion list (it starts ~2 rows tall and scrolls). -->
                <ToggleButton x:Name="MoreTags" HorizontalAlignment="Right" Cursor="Hand" Padding="4,0"
                              Background="Transparent" BorderThickness="0"
                              Visibility="{Binding HasSuggestions, Converter={StaticResource BoolToVis}}">
                    <TextBlock Foreground="{StaticResource Accent}" FontSize="11">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Show all  ▾" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsChecked, ElementName=MoreTags}" Value="True">
                                        <Setter Property="Text" Value="Show less  ▴" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </ToggleButton>
            </Grid>
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer">
                        <!-- ~2 rows of chips by default; the toggle opens it up (still scrolls). -->
                        <Setter Property="MaxHeight" Value="66" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsChecked, ElementName=MoreTags}" Value="True">
                                <Setter Property="MaxHeight" Value="210" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                <ItemsControl ItemsSource="{Binding Suggestions}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding}" Margin="0,0,6,6" Padding="9,3" Cursor="Hand"
                                    Background="#EEF1F6" BorderBrush="{StaticResource Line}" BorderThickness="1"
                                    Foreground="{StaticResource Ink}"
                                    Command="{Binding DataContext.PickTagCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </StackPanel>

        <DockPanel Grid.Row="5">
            <TextBlock DockPanel.Dock="Top" Text="NOTE" Foreground="{StaticResource Muted}" FontSize="11"
                       FontWeight="SemiBold" Margin="0,0,0,6" />
            <Border DockPanel.Dock="Top" Background="#FFF4E5" BorderBrush="#F0D6A8" BorderThickness="1"
                    CornerRadius="4" Padding="8,5" Margin="0,0,0,8"
                    Visibility="{Binding NoteHasExclusions, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="{Binding NoteExclusionText}" Foreground="#8A5A12" FontSize="11" TextWrapping="Wrap" />
            </Border>
            <TextBox Text="{Binding Note, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                     MinHeight="90" Padding="6,4" BorderBrush="{StaticResource Line}" BorderThickness="1" />
        </DockPanel>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Cancel" IsCancel="True" Padding="16,6" Margin="0,0,8,0" />
            <Button Content="Save" IsDefault="True" Padding="16,6" Click="OnSave"
                    Background="#E6EEFF" BorderBrush="{StaticResource Accent}" />
        </StackPanel>
    </Grid>
</Window>
