<Project Sdk="Microsoft.NET.Sdk">

  <ItemGroup>
    <ProjectReference Include="..\Aperture.Core\Aperture.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="VirtualizingWrapPanel" Version="2.5.2" />
  </ItemGroup>

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <ApplicationIcon>Assets\aperture.ico</ApplicationIcon>
    <AssemblyName>Aperture</AssemblyName>
    <Version>0.7.0-beta1</Version>
    <AssemblyTitle>Aperture Image Viewer</AssemblyTitle>
    <Product>Aperture Image Viewer</Product>
    <Description>A fast local image &amp; video browser for Windows.</Description>
    <Company>Funcular Labs</Company>
    <Authors>Funcular Labs</Authors>
    <Copyright>© 2026 Funcular Labs</Copyright>
  </PropertyGroup>

  <ItemGroup>
    <Resource Include="Assets\aperture.ico" />
    <Resource Include="Assets\mascot.png" />
  </ItemGroup>

  <ItemGroup>
    <!-- Ship the README next to the exe, with its images under docs/ so the relative
         paths resolve when the README is viewed from the distributed app folder.
         (Relative paths — not base64 — because GitHub sanitizes/rejects data: URIs.) -->
    <Content Include="..\..\README.md" Link="README.md" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="..\..\docs\logo.png" Link="docs\logo.png" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="..\..\docs\screenshot.png" Link="docs\screenshot.png" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
