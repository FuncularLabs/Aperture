<Window x:Class="Aperture.App.TagManagerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manage Tags" Height="480" Width="420"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize" MinWidth="340" MinHeight="300"
        Background="#F7F8FA" UseLayoutRounding="True" TextOptions.TextFormattingMode="Display"
        Icon="Assets/aperture.ico">
    <Window.Resources>
        <SolidColorBrush x:Key="Ink" Color="#1F2430" />
        <SolidColorBrush x:Key="Muted" Color="#8A90A0" />
        <SolidColorBrush x:Key="Accent" Color="#3A72F0" />
        <SolidColorBrush x:Key="Line" Color="#E2E5EA" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Manage tags" Foreground="{StaticResource Ink}" FontWeight="Bold"
                   FontSize="15" Margin="0,0,0,4" />
        <TextBlock Grid.Row="1" Text="Edit a name and press Enter to rename (renaming onto an existing tag merges them). The count is how many files use each tag."
                   Foreground="{StaticResource Muted}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,12" />

        <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="4">
            <Grid>
                <TextBlock Text="No tags yet — add some from a photo's “Tags &amp; notes…” menu."
                           Foreground="{StaticResource Muted}" FontSize="12" TextWrapping="Wrap"
                           HorizontalAlignment="Center" VerticalAlignment="Center" Margin="24"
                           TextAlignment="Center"
                           Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}" />
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Tags}" Margin="4">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="4,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="6,4" BorderBrush="{StaticResource Line}" BorderThickness="1"
                                             VerticalContentAlignment="Center">
                                        <TextBox.InputBindings>
                                            <KeyBinding Key="Return"
                                                        Command="{Binding DataContext.RenameCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}" />
                                        </TextBox.InputBindings>
                                    </TextBox>
                                    <Border Grid.Column="1" Background="#EEF1F6" CornerRadius="9" Padding="8,2" Margin="6,0"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Count}" Foreground="{StaticResource Muted}" FontSize="11" />
                                    </Border>
                                    <Button Grid.Column="2" Content="Delete" Padding="10,4" Cursor="Hand"
                                            Foreground="#B03A3A" Background="#FDECEC" BorderBrush="#F2C4C4" BorderThickness="1"
                                            Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Close" IsCancel="True" IsDefault="True" Padding="16,6" />
        </StackPanel>
    </Grid>
</Window>
